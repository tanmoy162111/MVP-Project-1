APP_NAME="Electronics Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Dhaka

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── DATABASE ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=electronics_platform
DB_USERNAME=root
DB_PASSWORD=

# ── CACHE / SESSION / QUEUE ──────────────────────────────────────────────────
BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── REDIS ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── MAIL ─────────────────────────────────────────────────────────────────────
# Provider: SendGrid or Resend — fill in after you create account
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=           # <-- YOUR SENDGRID API KEY
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── SANCTUM ──────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# ── MEILISEARCH (Phase 2 — product search) ──────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=              # <-- YOUR MEILISEARCH MASTER KEY

# ── PAYMENT GATEWAYS (Phase 3) ───────────────────────────────────────────────
# bKash
BKASH_APP_KEY=                # <-- FROM BKASH MERCHANT PORTAL
BKASH_APP_SECRET=             # <-- FROM BKASH MERCHANT PORTAL
BKASH_USERNAME=               # <-- FROM BKASH MERCHANT PORTAL
BKASH_PASSWORD=               # <-- FROM BKASH MERCHANT PORTAL
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta # change to prod URL for live

# SSLCommerz
SSLCZ_STORE_ID=               # <-- FROM SSLCOMMERZ DASHBOARD
SSLCZ_STORE_PASSWORD=         # <-- FROM SSLCOMMERZ DASHBOARD
SSLCZ_SANDBOX=true            # set false for production

# ── FILE STORAGE (Local VPC) ─────────────────────────────────────────────────
FILESYSTEM_DISK=local
# When VPC NFS/S3-compatible storage is ready, switch to:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_ENDPOINT=               # <-- YOUR VPC S3-COMPATIBLE ENDPOINT

# ── OPIS PRICING (Phase 4) ───────────────────────────────────────────────────
OPIS_API_URL=                 # <-- OPIS FEED URL (provided by your OPIS account)
OPIS_API_KEY=                 # <-- OPIS API KEY

# ── ADMIN ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=changeme123    # change immediately after first deploy
